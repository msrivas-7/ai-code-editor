# Copy to .env and edit as needed. All variables are optional; defaults are fine for local dev.

# --- Backend ---
PORT=4000
CORS_ORIGIN=http://localhost:5173

# Name of the pre-built polyglot runner image.
RUNNER_IMAGE=ai-code-editor-runner:latest

# Per-session idle timeout and how often the sweeper runs. Both in milliseconds.
SESSION_IDLE_TIMEOUT_MS=120000
SESSION_SWEEP_INTERVAL_MS=45000

# Per-run resource limits for spawned runner containers.
RUNNER_MEMORY_BYTES=536870912
RUNNER_NANO_CPUS=1000000000
RUN_TIMEOUT_MS=10000

# Backend-internal path where per-session workspaces live. Always a Linux
# path because the backend runs in a Linux container. Leave as the default
# when running via docker compose; override only if you've changed the bind
# mount in docker-compose.yml.
# WORKSPACE_ROOT=/workspace-root

# Escape hatch: host-side absolute path that backs WORKSPACE_ROOT.
# Normally discovered automatically at startup via Docker self-inspect, which
# works identically on macOS, Linux, and Windows. Only set this when running
# the backend directly on the host (outside docker compose).
# Unix example:    /absolute/path/to/AICodeEditor/temp/sessions
# Windows example: C:\path\to\AICodeEditor\temp\sessions
# WORKSPACE_ROOT_HOST=

# --- Frontend (only used when running Vite directly) ---
VITE_BACKEND_URL=http://localhost:4000

# --- Supabase (auth provider, Phase 18a+) ---
# DEV: values below are the well-known defaults produced by the local
# `supabase start` stack. They are NOT secret — they ship in the Supabase CLI
# and are the same on every contributor's machine. Run `npx supabase status`
# to print the current values (useful if the CLI ever regenerates them).
#
# PROD: override all three in .env.production with values from Project Settings
# → API in the Supabase dashboard. The backend verifies tokens via the
# Supabase auth server's JWKS endpoint — there is NO shared-secret env var
# (e.g. JWT_SECRET) to set. Verification is asymmetric.

# The backend (in Docker) reaches the host-run Supabase stack via
# host.docker.internal. On Linux, docker-compose.yml adds an extra_hosts
# entry so this resolves identically.
SUPABASE_URL=http://host.docker.internal:54321

# Frontend reaches Supabase directly from the browser, which runs on the host —
# hence localhost, not host.docker.internal.
VITE_SUPABASE_URL=http://localhost:54321
# Public anon key. Safe to ship in the frontend bundle.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# --- E2E only ---
# Service-role key for the Supabase local stack. Playwright uses this to
# admin-create / delete test users in global setup/teardown so specs don't
# have to click through the signup UI. Safe for dev (it's the CLI's
# well-known local key). NEVER set this for prod — production tests should
# run against a dedicated staging project with its own service_role key.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
