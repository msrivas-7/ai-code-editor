# Copy to `frontend/.env.development.local` (gitignored) and fill in real
# values from the `codetutor-dev` Supabase project. Vite auto-loads
# `.env.development.local` when running `vite dev` on the host.
#
# These two values must match the `VITE_SUPABASE_*` entries in the root
# `.env` (which docker compose uses when Vite runs inside the frontend
# container). Keep them in sync so `npm run dev` and `docker compose up`
# behave identically.
#
# Both values are PUBLIC — the publishable key is designed to be shipped in
# the browser bundle.

VITE_SUPABASE_URL=https://<your-dev-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-dev-publishable-key>
