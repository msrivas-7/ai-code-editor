{
  "id": "functions",
  "courseId": "python-fundamentals",
  "title": "Functions",
  "description": "Organize code into reusable functions.",
  "order": 6,
  "language": "python",
  "estimatedMinutes": 20,
  "objectives": [
    "Define functions with def",
    "Use parameters and return values",
    "Understand scope (local vs global)"
  ],
  "teachesConceptTags": [
    "def",
    "parameters",
    "return",
    "scope",
    "default-arguments"
  ],
  "usesConceptTags": [
    "variables",
    "if",
    "elif",
    "else",
    "comparison",
    "int",
    "float",
    "str",
    "print",
    "f-strings"
  ],
  "completionRules": [
    {
      "type": "required_file_contains",
      "file": "main.py",
      "pattern": "def "
    },
    {
      "type": "required_file_contains",
      "file": "main.py",
      "pattern": "return "
    },
    {
      "type": "function_tests",
      "tests": [
        {
          "name": "celsius_to_fahrenheit freezing point",
          "call": "celsius_to_fahrenheit(0)",
          "expected": "32.0"
        },
        {
          "name": "celsius_to_fahrenheit boiling point",
          "call": "celsius_to_fahrenheit(100)",
          "expected": "212.0"
        },
        {
          "name": "celsius_to_fahrenheit room temp",
          "call": "celsius_to_fahrenheit(25)",
          "expected": "77.0"
        },
        {
          "name": "classify_temp below freezing",
          "call": "classify_temp(20)",
          "expected": "'freezing'"
        },
        {
          "name": "classify_temp cold range",
          "call": "classify_temp(50)",
          "expected": "'cold'"
        },
        {
          "name": "classify_temp comfortable range",
          "call": "classify_temp(72)",
          "expected": "'comfortable'"
        },
        {
          "name": "classify_temp hot range",
          "call": "classify_temp(95)",
          "expected": "'hot'"
        },
        {
          "name": "celsius_to_fahrenheit negative",
          "call": "celsius_to_fahrenheit(-40)",
          "expected": "-40.0",
          "hidden": true,
          "category": "negative-temperatures"
        },
        {
          "name": "classify_temp boundary cold→comfortable",
          "call": "classify_temp(60)",
          "expected": "'comfortable'",
          "hidden": true,
          "category": "range-boundaries"
        },
        {
          "name": "classify_temp boundary comfortable→hot",
          "call": "classify_temp(80)",
          "expected": "'hot'",
          "hidden": true,
          "category": "range-boundaries"
        }
      ]
    }
  ],
  "prerequisiteLessonIds": [
    "loops"
  ],
  "recap": "Functions let you name a block of code and reuse it. They take parameters, do work, and return results. This keeps your code organized and DRY.",
  "practicePrompts": [
    "Write a function that takes a list of numbers and returns the largest one.",
    "Can you write a function with a default parameter?"
  ],
  "practiceExercises": [
    {
      "id": "square-function",
      "title": "Square function",
      "prompt": "Write a function `square(n)` that returns n * n. The grader will test it with several values.",
      "goal": "Define a function with one parameter and a return value.",
      "starterCode": "# TODO: Define square(n) that returns n * n\ndef square(n):\n    pass\n",
      "completionRules": [
        { "type": "required_file_contains", "file": "main.py", "pattern": "def square" },
        {
          "type": "function_tests",
          "tests": [
            { "name": "square of 5", "call": "square(5)", "expected": "25" },
            { "name": "square of 0", "call": "square(0)", "expected": "0" },
            { "name": "square of 7", "call": "square(7)", "expected": "49" },
            { "name": "square of a negative", "call": "square(-3)", "expected": "9", "hidden": true, "category": "negative-input" }
          ]
        }
      ],
      "hints": [
        "def square(n):",
        "    return n * n",
        "Multiplying a negative by a negative gives a positive, so square(-3) should be 9."
      ]
    },
    {
      "id": "greet-default",
      "title": "Greeting with default",
      "prompt": "Write `greet(name, greeting=\"Hello\")` that returns `<greeting>, <name>!`. The grader will test it with and without the second argument.",
      "goal": "Use a default parameter value.",
      "starterCode": "# TODO: Define greet(name, greeting=\"Hello\") that returns f\"{greeting}, {name}!\"\ndef greet(name, greeting=\"Hello\"):\n    pass\n",
      "completionRules": [
        { "type": "required_file_contains", "file": "main.py", "pattern": "def greet" },
        {
          "type": "function_tests",
          "tests": [
            { "name": "default greeting", "call": "greet('Sam')", "expected": "'Hello, Sam!'" },
            { "name": "custom greeting", "call": "greet('Sam', 'Hi')", "expected": "'Hi, Sam!'" },
            { "name": "different name with default", "call": "greet('Alice')", "expected": "'Hello, Alice!'" },
            { "name": "another custom greeting", "call": "greet('Bob', 'Hey')", "expected": "'Hey, Bob!'", "hidden": true, "category": "default-override" }
          ]
        }
      ],
      "hints": [
        "Default values go in the function definition: `def greet(name, greeting=\"Hello\"):`.",
        "Return an f-string: `return f\"{greeting}, {name}!\"`.",
        "Note the exact format: `Hello, Sam!` — comma, space, exclamation mark."
      ]
    },
    {
      "id": "max-of-three",
      "title": "Max of three numbers",
      "prompt": "Write a function `max_of_three(a, b, c)` that returns the largest of the three numbers WITHOUT using Python's built-in `max()`. The grader will test it with several combinations.",
      "goal": "Compare three values using if/elif and return the largest.",
      "starterCode": "# TODO: Define max_of_three(a, b, c) — don't use built-in max()\ndef max_of_three(a, b, c):\n    pass\n",
      "completionRules": [
        { "type": "required_file_contains", "file": "main.py", "pattern": "def max_of_three" },
        { "type": "required_file_contains", "file": "main.py", "pattern": "return " },
        {
          "type": "function_tests",
          "tests": [
            { "name": "b is the largest", "call": "max_of_three(4, 9, 7)", "expected": "9" },
            { "name": "c is the largest", "call": "max_of_three(1, 2, 3)", "expected": "3" },
            { "name": "a is the largest", "call": "max_of_three(10, 5, 2)", "expected": "10" },
            { "name": "two tied at the top", "call": "max_of_three(5, 5, 3)", "expected": "5", "hidden": true, "category": "ties" },
            { "name": "all negatives", "call": "max_of_three(-1, -2, -3)", "expected": "-1", "hidden": true, "category": "negatives" }
          ]
        }
      ],
      "hints": [
        "Compare a to b first to find the larger of the first two.",
        "Then compare that to c to find the overall largest.",
        "You can chain comparisons with `and`: `if a >= b and a >= c: return a`."
      ]
    }
  ]
}
