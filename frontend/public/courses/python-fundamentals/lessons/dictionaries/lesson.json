{
  "id": "dictionaries",
  "courseId": "python-fundamentals",
  "title": "Dictionaries",
  "description": "Store data as key-value pairs for fast lookup.",
  "order": 8,
  "language": "python",
  "estimatedMinutes": 20,
  "objectives": [
    "Create and access dictionaries",
    "Add, update, and remove key-value pairs",
    "Iterate over keys, values, and items",
    "Use .get() for safe access"
  ],
  "teachesConceptTags": [
    "dict",
    "key-value",
    "get",
    "items",
    "keys",
    "values",
    "nesting"
  ],
  "usesConceptTags": [
    "list",
    "def",
    "return",
    "for",
    "iteration",
    "print",
    "str",
    "int",
    "if",
    "variables"
  ],
  "completionRules": [
    {
      "type": "required_file_contains",
      "file": "main.py",
      "pattern": "def count_words"
    },
    {
      "type": "required_file_contains",
      "file": "main.py",
      "pattern": "def most_frequent"
    },
    {
      "type": "function_tests",
      "tests": [
        {
          "name": "count_words counts repeats",
          "call": "count_words(['apple', 'banana', 'apple'])",
          "expected": "{'apple': 2, 'banana': 1}"
        },
        {
          "name": "count_words single word",
          "call": "count_words(['hi'])",
          "expected": "{'hi': 1}"
        },
        {
          "name": "count_words all unique",
          "call": "count_words(['a', 'b', 'c'])",
          "expected": "{'a': 1, 'b': 1, 'c': 1}"
        },
        {
          "name": "most_frequent picks the top count",
          "call": "most_frequent({'apple': 3, 'banana': 1, 'cherry': 2})",
          "expected": "'apple'"
        },
        {
          "name": "most_frequent breaks ties alphabetically",
          "call": "most_frequent({'banana': 2, 'apple': 2, 'cherry': 2})",
          "expected": "'apple'"
        },
        {
          "name": "count_words empty list",
          "call": "count_words([])",
          "expected": "{}",
          "hidden": true,
          "category": "empty-input"
        },
        {
          "name": "most_frequent with single entry",
          "call": "most_frequent({'only': 7})",
          "expected": "'only'",
          "hidden": true,
          "category": "minimal-input"
        }
      ]
    }
  ],
  "prerequisiteLessonIds": [
    "lists"
  ],
  "recap": "Dictionaries map keys to values for fast lookups. They're perfect for structured data like records, configs, and counters.",
  "practicePrompts": [
    "Count how many times each word appears in a sentence using a dictionary.",
    "Can you merge two dictionaries together?"
  ],
  "practiceExercises": [
    {
      "id": "word-count",
      "title": "Word frequency",
      "prompt": "Write a function `word_counts(text)` that splits `text` on whitespace and returns a dict counting how often each word appears. The grader will test it with several strings.",
      "goal": "Count occurrences with a dictionary and .get().",
      "starterCode": "def word_counts(text):\n    # Return a dict mapping each word to its count\n    pass\n",
      "completionRules": [
        { "type": "required_file_contains", "file": "main.py", "pattern": "def word_counts" },
        { "type": "required_file_contains", "file": "main.py", "pattern": ".get(" },
        {
          "type": "function_tests",
          "tests": [
            { "name": "basic sentence with repeats", "call": "word_counts('to be or not to be')", "expected": "{'to': 2, 'be': 2, 'or': 1, 'not': 1}" },
            { "name": "single word", "call": "word_counts('hello')", "expected": "{'hello': 1}" },
            { "name": "all unique words", "call": "word_counts('a b c')", "expected": "{'a': 1, 'b': 1, 'c': 1}" },
            { "name": "empty string returns empty dict", "call": "word_counts('')", "expected": "{}", "hidden": true, "category": "empty-input" }
          ]
        }
      ],
      "hints": [
        "Split first: `words = text.split()`.",
        "Loop over words: `counts[word] = counts.get(word, 0) + 1`.",
        "`split()` with no argument handles multiple spaces and returns `[]` for an empty string."
      ]
    },
    {
      "id": "safe-lookup",
      "title": "Safe price lookup",
      "prompt": "Write a function `price_of(prices, item)` that returns the price for `item` using `.get()` with a default of `0.0` when the item isn't in the dict. The grader will test it with several price sheets.",
      "goal": "Use .get() to avoid KeyError on missing keys.",
      "starterCode": "def price_of(prices, item):\n    # Return prices[item], or 0.0 if item is missing — use .get()\n    pass\n",
      "completionRules": [
        { "type": "required_file_contains", "file": "main.py", "pattern": "def price_of" },
        { "type": "required_file_contains", "file": "main.py", "pattern": ".get(" },
        {
          "type": "function_tests",
          "tests": [
            { "name": "existing item", "call": "price_of({'apple': 1.0, 'banana': 0.5}, 'apple')", "expected": "1.0" },
            { "name": "missing item defaults to 0.0", "call": "price_of({'apple': 1.0, 'banana': 0.5}, 'cherry')", "expected": "0.0" },
            { "name": "empty dict", "call": "price_of({}, 'anything')", "expected": "0.0" },
            { "name": "zero-priced item stays zero", "call": "price_of({'free': 0.0, 'apple': 1.0}, 'free')", "expected": "0.0", "hidden": true, "category": "zero-value" }
          ]
        }
      ],
      "hints": [
        "`prices.get(item, 0.0)` returns 0.0 if the key doesn't exist.",
        "That's a one-liner: `return prices.get(item, 0.0)`.",
        "Don't check `if item in prices` — that's what `.get()` replaces."
      ]
    },
    {
      "id": "merge-dicts",
      "title": "Merge two dicts",
      "prompt": "Write a function `merge(a, b)` that returns a new dict containing all keys from both `a` and `b`. When a key appears in both, `b`'s value wins. The grader will test it with several pairs.",
      "goal": "Combine two dictionaries by iterating.",
      "starterCode": "def merge(a, b):\n    # Return a merged dict where b's values win on collision\n    pass\n",
      "completionRules": [
        { "type": "required_file_contains", "file": "main.py", "pattern": "def merge" },
        {
          "type": "function_tests",
          "tests": [
            { "name": "overlapping keys, b wins", "call": "merge({'x': 1, 'y': 2}, {'y': 20, 'z': 30})", "expected": "{'x': 1, 'y': 20, 'z': 30}" },
            { "name": "disjoint keys", "call": "merge({'a': 1}, {'b': 2})", "expected": "{'a': 1, 'b': 2}" },
            { "name": "empty a", "call": "merge({}, {'z': 9})", "expected": "{'z': 9}" },
            { "name": "empty b leaves a unchanged", "call": "merge({'a': 1, 'b': 2}, {})", "expected": "{'a': 1, 'b': 2}", "hidden": true, "category": "empty-override" }
          ]
        }
      ],
      "hints": [
        "Start with `merged = {}`; loop `for k, v in a.items(): merged[k] = v`.",
        "Then overwrite with `b`: `for k, v in b.items(): merged[k] = v`.",
        "Finally `return merged`."
      ]
    }
  ]
}
