# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND PRODUCTION ENV TEMPLATE
# ─────────────────────────────────────────────────────────────────────────────
# Copy to `frontend/.env.production.local` (gitignored) and fill in real
# values from the `codetutor-prod` Supabase project. Vite reads this file
# automatically when building with `vite build` (mode=production). Values
# are baked into the bundle at build time — rebuild after any change.
#
# Both values are PUBLIC — the publishable key is designed to be shipped in
# the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://<your-prod-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-prod-publishable-key>
