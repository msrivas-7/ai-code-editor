# Vitest runs with mode=test by default and therefore loads THIS file. Mirror
# the .env.development values so supabaseClient's import-time env check
# passes; tests don't actually talk to Supabase (they mock at the api layer),
# so any non-empty string works, but using the real dev values keeps tests
# closer to production behaviour if a test does accidentally reach through.
VITE_SUPABASE_URL=http://127.0.0.1:54321
