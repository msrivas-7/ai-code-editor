# Vitest runs with mode=test and loads THIS file. Unit tests mock the api
# layer and never actually reach Supabase, so these values just need to
# satisfy supabaseClient's import-time env check — any non-empty strings
# work. Committed intentionally (not a credential file).
VITE_SUPABASE_URL=https://test.supabase.invalid
VITE_SUPABASE_ANON_KEY=sb_publishable_test_placeholder_not_a_real_key
