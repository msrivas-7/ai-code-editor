{
  "name": "codetutor-ai-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "lint:content": "tsx scripts/content-lint.ts",
    "verify:solutions": "tsx scripts/verify-solutions.ts",
    "new:lesson": "tsx scripts/new-lesson.ts",
    "new:practice": "tsx scripts/new-practice.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@supabase/supabase-js": "^2.103.3",
    "canvas-confetti": "^1.9.4",
    "monaco-editor": "^0.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  }
}
