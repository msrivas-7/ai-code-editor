node_modules/
dist/
build/
# Env files: only *.example templates are committed. Real values live in
# gitignored files populated on the deploy target (or by CI secrets).
.env
.env.production
.env.*.local

# Dev-only test-user credentials (backend/scripts/seed-dev-users.ts output).
# Password is shared + written into auth.users on codetutor-dev; keep it out
# of git.
.dev-users.md
.DS_Store
*.log
*.tsbuildinfo

# Per-session workspaces written by backend at runtime. Directory is created
# on demand by docker-compose (bind-mount source), cloud-init, and the
# backend's createSession(); no tracked placeholder needed.
temp/sessions/

# Terminal window IDs recorded by start.sh for stop.sh to close
.ai-code-editor-terminals
.codetutor-ai-terminals

# Editor / tooling
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.claude/
.agents/

# Playwright E2E artifacts (e2e/ has its own .gitignore; these catch stray
# outputs when playwright is invoked from the repo root).
test-results/
playwright-report/
blob-report/
.playwright/

# Supabase CLI scratch dir (created by `npx supabase db push` etc.)
supabase/.temp/

# Ops scratch dir — restore drills, oncall handoffs, raw command logs,
# plus `ops/runbook-values.local.md` (live resource names, last rotation
# dates, deployer CIDR). Keep these local so we can scribble real values
# freely. `.example` templates + README sit alongside so new operators
# have a starting point.
ops/*
!ops/README.md
!ops/*.example.md

# QA-M1: generated at dev-server start + build-start by
# scripts/vitePluginCourseRegistry.ts. Source of truth is the folder layout
# under frontend/public/courses/; this manifest is a cached enumeration.
frontend/public/courses/registry.json
